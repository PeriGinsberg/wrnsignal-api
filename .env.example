# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=price_1TL2XTAiNxFDFWtLwubm6stk

# ── Attribution / Conversion APIs ──
# Fired from /api/webhooks/stripe (checkout.session.completed +
# charge.refunded) and /api/stripe/refund (user-initiated refund). Each
# provider skips silently when its required env vars are unset, so this
# file can ship with empty placeholders and the webhook still deploys
# safely. Full operational onboarding steps live in
# docs/ATTRIBUTION_ARCHITECTURE.md.

# Meta Conversions API
# Pixel ID (15–16 digits) from Meta Events Manager → Data Sources
META_PIXEL_ID=
# Long-lived CAPI access token (Events Manager → Settings → CAPI)
META_CAPI_ACCESS_TOKEN=

# TikTok Events API
# Pixel code from TikTok Events Manager → Manage Events
TIKTOK_PIXEL_ID=
# Events API access token (Events Manager → Settings → Events API)
TIKTOK_EVENTS_API_TOKEN=

# Google Ads API (server-side conversion uploads)
# Setup is heavier than the other three platforms — developer token
# requires 24–48h approval from the Google Ads API Center; refresh token
# is a one-time manual OAuth flow.
# Developer token from the Google Ads API Center
GOOGLE_ADS_DEVELOPER_TOKEN=
# OAuth client from Google Cloud Console → APIs & Services → Credentials
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# Refresh token generated via OAuth Playground (one-time)
GOOGLE_ADS_REFRESH_TOKEN=
# Ad account customer ID (no dashes, e.g. "1234567890")
GOOGLE_ADS_CUSTOMER_ID=
# Numeric conversion action ID from Google Ads UI → Tools → Conversions
GOOGLE_ADS_CONVERSION_ACTION_ID=
# Optional: manager (MCC) account customer ID, only set when ad account is MCC-managed
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# GA4 Measurement Protocol
# Measurement ID, e.g. "G-XXXXXXXXXX"
GA4_MEASUREMENT_ID=
# API secret from GA4 Admin → Data Streams → (stream) → Measurement Protocol
GA4_API_SECRET=
